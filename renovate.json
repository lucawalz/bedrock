{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "nix": {
    "enabled": true
  },
  "flux": {
    "enabled": true,
    "fileMatch": ["kubernetes/.+\\.ya?ml$"]
  },
  "github-actions": {
    "enabled": true
  },
  "rebaseWhen": "conflicted",
  "platformAutomerge": true,
  "timezone": "Europe/Berlin",
  "packageRules": [
    {
      "description": "Group all nixpkgs flake updates together",
      "matchManagers": ["nix"],
      "groupName": "nixpkgs"
    },
    {
      "description": "Group infrastructure Helm charts together",
      "matchManagers": ["flux"],
      "groupName": "infrastructure charts",
      "schedule": ["on sunday"],
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": [
        "/cert-manager/",
        "/traefik/",
        "/longhorn/",
        "/kube-prometheus-stack/"
      ]
    },
    {
      "description": "App charts updated individually for easier review",
      "matchManagers": ["flux"],
      "groupName": "app charts",
      "matchPackageNames": [
        "/n8n/"
      ]
    },
    {
      "description": "Auto-merge minor, patch, and digest updates",
      "matchUpdateTypes": ["minor", "patch", "digest", "pin"],
      "automerge": true
    },
    {
      "description": "Hold major updates for manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Hold critical infrastructure minors and patches for manual review",
      "matchManagers": ["flux"],
      "matchPackageNames": [
        "/^longhorn$/",
        "/^cloudnative-pg$/",
        "/^kube-prometheus-stack$/",
        "/^velero$/",
        "/^cert-manager$/",
        "/^traefik$/",
        "/^authentik$/",
        "/^rancher$/",
        "/^metallb$/"
      ],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": false
    },
    {
      "description": "Step stateful infrastructure one minor at a time",
      "matchManagers": ["flux"],
      "matchPackageNames": [
        "/^longhorn$/",
        "/^cloudnative-pg$/",
        "/^kube-prometheus-stack$/",
        "/^velero$/",
        "/^cert-manager$/"
      ],
      "separateMultipleMinor": true
    }
  ]
}
